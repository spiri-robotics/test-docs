{
  "// what this is": "A ready-made writing environment. Opening this folder in VS Code with Docker running gives you Sphinx, a live preview, and the Vale style checker with nothing to install by hand. See CONTRIBUTING.md.",

  "name": "Spiri Documentation Test Build",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",

  // The live preview. VS Code forwards it automatically and offers to open it.
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Manual preview",
      "onAutoForward": "openPreview"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "executablebookproject.myst-highlight",
        "streetsidesoftware.code-spell-checker",
        "redhat.vscode-yaml",
        "chrischinchilla.vale-vscode",
        // So the finished PDF opens in a tab when the build is done. Without
        // it VS Code treats a .pdf as a binary file and offers to download it,
        // which is a strange thing to be offered for a file you just made.
        "tomoki1207.pdf"
      ],
      "settings": {
        // Python lives here only to build the document; nobody writing the
        // manual should be shown Python tooling.
        "python.defaultInterpreterPath": "/workspaces/spiri-documentation-test-build/.venv/bin/python"
      }
    }
  }
}
